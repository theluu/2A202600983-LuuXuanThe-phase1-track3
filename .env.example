# Sao chép file này thành .env rồi điền giá trị để chạy benchmark với LLM thật.
# python run_benchmark.py --dataset data/benchmark_set.json --runtime openai

OPENAI_API_KEY=sk-...
# Tùy chọn: đổi model (mặc định gpt-4o-mini)
OPENAI_MODEL=gpt-4o-mini
# Tùy chọn: trỏ tới endpoint OpenAI-compatible (Ollama/vLLM/Groq...)
# OPENAI_BASE_URL=http://localhost:11434/v1
